<Window x:Class="HuffleDesktopPet.PetOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HuffleDesktopPet"
        Width="128" Height="128"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <!--
        Milestone F — sprite animation layer
        Window is now 128x128 (64x64 sprites at 2x integer upscale).
        PlaceholderGrid shows when no sprites are found (fallback).
        PetSprite shows when sprites are loaded; flips horizontally via SpriteFlip.
    -->
    <Grid x:Name="RootGrid">

        <Grid.ToolTip>
            <ToolTip>
                <TextBlock x:Name="NeedsText" FontSize="11" FontFamily="Consolas"/>
            </ToolTip>
        </Grid.ToolTip>

        <!-- Right-click context menu on the pet body -->
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Feed"  Click="OnFeedClick"/>
                <MenuItem Header="Play"  Click="OnPlayClick"/>
                <MenuItem Header="Clean" Click="OnCleanClick"/>
                <MenuItem Header="Study" Click="OnStudyClick"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <!-- ═══ PLACEHOLDER (shown when sprites are not loaded) ═══════════════ -->
        <Grid x:Name="PlaceholderGrid">

            <!-- Body — tinted by code-behind to reflect need states -->
            <Ellipse x:Name="PetBody"
                     Width="80" Height="80"
                     Fill="#CC7B5EA6"
                     Stroke="#FF4A2D7A"
                     StrokeThickness="3"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>

            <!-- Face (128x128 window, 80x80 body centred at 64,64) -->
            <Canvas IsHitTestVisible="False">
                <!-- Left eye white -->
                <Ellipse Canvas.Left="38" Canvas.Top="47" Width="12" Height="12" Fill="White"/>
                <!-- Right eye white -->
                <Ellipse Canvas.Left="78" Canvas.Top="47" Width="12" Height="12" Fill="White"/>
                <!-- Left pupil -->
                <Ellipse Canvas.Left="42" Canvas.Top="51" Width="6"  Height="6"  Fill="#1A1A2E"/>
                <!-- Right pupil -->
                <Ellipse Canvas.Left="82" Canvas.Top="51" Width="6"  Height="6"  Fill="#1A1A2E"/>
                <!-- Smile (happy — default) -->
                <Path x:Name="PetSmile"
                      Canvas.Left="48" Canvas.Top="68"
                      Stroke="#1A1A2E" StrokeThickness="2.5" StrokeLineCap="Round"
                      Data="M 0,0 Q 8,8 16,0"/>
                <!-- Frown (shown when any need is critical) -->
                <Path x:Name="PetFrown"
                      Canvas.Left="48" Canvas.Top="76"
                      Stroke="#1A1A2E" StrokeThickness="2.5" StrokeLineCap="Round"
                      Visibility="Collapsed"
                      Data="M 0,0 Q 8,-8 16,0"/>
            </Canvas>
        </Grid>

        <!-- ═══ SPRITE (shown when sprites are loaded) ════════════════════════ -->
        <!--
            Stretch="None"  + Width/Height=128 → sprites display at native 128x128
            (64x64 source at 2x integer upscale set by the BitmapImage.DecodePixelWidth).
            NearestNeighbor prevents blurring on integer upscale.
            SpriteFlip.ScaleX = -1 mirrors for left-facing movement.
        -->
        <Image x:Name="PetSprite"
               Width="128" Height="128"
               Stretch="None"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               SnapsToDevicePixels="True"
               Visibility="Collapsed"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <ScaleTransform x:Name="SpriteFlip"/>
            </Image.RenderTransform>
        </Image>

        <!-- ═══ PARTICLE OVERLAY ════════════════════════════════════════════ -->
        <!--
            Code-behind populates this with Zzz (sleep) and heart (happy) TextBlocks.
            IsHitTestVisible=False so clicks pass through to the pet sprite/drag logic.
            Particles are positioned via Canvas.SetLeft/Top and fade via Opacity.
        -->
        <Canvas x:Name="ParticleCanvas" IsHitTestVisible="False"/>

    </Grid>
</Window>
