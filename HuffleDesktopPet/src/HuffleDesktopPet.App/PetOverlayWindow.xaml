<Window x:Class="HuffleDesktopPet.PetOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HuffleDesktopPet"
        Width="120" Height="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <!--
        PLACEHOLDER PET — purple circle with eyes.
        Replace with real sprite (Image tag) once assets are ready.
        Window background is fully transparent; only these shapes render.
    -->
    <Grid x:Name="RootGrid">
        <Grid.ToolTip>
            <ToolTip>
                <TextBlock x:Name="NeedsText" FontSize="11" FontFamily="Consolas"/>
            </ToolTip>
        </Grid.ToolTip>

        <!-- Body -->
        <Ellipse Width="80" Height="80"
                 Fill="#CC7B5EA6"
                 Stroke="#FF4A2D7A"
                 StrokeThickness="3"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>

        <!-- Face (120x120 window, 80x80 body centred at 60,60) -->
        <Canvas IsHitTestVisible="False">
            <!-- Left eye white -->
            <Ellipse Canvas.Left="34" Canvas.Top="43" Width="12" Height="12" Fill="White"/>
            <!-- Right eye white -->
            <Ellipse Canvas.Left="74" Canvas.Top="43" Width="12" Height="12" Fill="White"/>
            <!-- Left pupil -->
            <Ellipse Canvas.Left="38" Canvas.Top="47" Width="6"  Height="6"  Fill="#1A1A2E"/>
            <!-- Right pupil -->
            <Ellipse Canvas.Left="78" Canvas.Top="47" Width="6"  Height="6"  Fill="#1A1A2E"/>
            <!-- Smile -->
            <Path Canvas.Left="44" Canvas.Top="64"
                  Stroke="#1A1A2E" StrokeThickness="2.5" StrokeLineCap="Round"
                  Data="M 0,0 Q 8,8 16,0"/>
        </Canvas>
    </Grid>
</Window>
